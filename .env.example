# ============================================================
# AI Book Detection — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- LLM Provider: "openai" | "ollama" ---
LLM_PROVIDER=openai

# --- OpenAI (required if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=200
OPENAI_TEMPERATURE=0.0

# --- Ollama (required if LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Detection weights (must sum to 1.0) ---
LLM_WEIGHT=0.6
HEURISTIC_WEIGHT=0.4

# --- Chunking ---
CHUNK_MIN_WORDS=300
CHUNK_MAX_WORDS=500

# --- Confidence thresholds (variance of chunk scores) ---
HIGH_CONFIDENCE_VARIANCE_THRESHOLD=0.03
MEDIUM_CONFIDENCE_VARIANCE_THRESHOLD=0.08

# --- High-risk threshold ---
HIGH_RISK_THRESHOLD=0.70

# --- File upload ---
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/ai_detection_uploads

# --- Concurrency ---
LLM_CONCURRENCY_LIMIT=5
